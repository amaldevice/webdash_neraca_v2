# Salin ke `.env` di root repo (file `.env` diabaikan git).
# Nilai yang sudah di-set di lingkungan proses (systemd, Docker, shell) tidak ditimpa oleh file ini.

# --- Wajib produksi (FLASK_ENV=production) ---
# DSN SQLAlchemy (lihat README contoh mysql/postgresql/sqlite)
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DBNAME?charset=utf8mb4
#
# Konfigurasi MySQL (template lokal/Docker):
# MYSQL_ROOT_PASSWORD=ubah_di_lokal
# MYSQL_DATABASE=webdash
# MYSQL_USER=webdash
# MYSQL_PASSWORD=ubah_di_lokal
# MYSQL_HOST_PORT=3306
# Jika app jalan di host (bukan container), pakai DSN ini:
# DATABASE_URL=mysql+pymysql://webdash:ubah_di_lokal@127.0.0.1:3306/webdash?charset=utf8mb4
# Untuk operasi MySQL internal tools/migrasi:
# MYSQL_TARGET_URL=mysql+pymysql://webdash:ubah_di_lokal@127.0.0.1:3306/webdash?charset=utf8mb4
# MYSQL_SOURCE_URL=mysql+pymysql://webdash:ubah_di_lokal@127.0.0.1:3306/webdash?charset=utf8mb4
# MIGRATE_TARGET_URL=mysql+pymysql://webdash:ubah_di_lokal@127.0.0.1:3306/webdash?charset=utf8mb4

# Secret penandatanganan cookie sesi (gunakan string panjang acak)
# FLASK_SECRET_KEY=

# --- Lingkungan Flask ---
# FLASK_ENV=development
# FLASK_RUN_PORT=5000

# --- Opsional keamanan / sesi ---
# Set ke 1 jika aplikasi hanya di-serve lewat HTTPS (cookie Secure)
# SESSION_COOKIE_SECURE=0

# Gagal start jika secret masih default `change-me-for-production` (setelah FLASK_SECRET_KEY kuat)
# REQUIRE_FLASK_SECRET=0

# --- Rate limit unggahan (routes/upload) ---
# UPLOAD_RATE_LIMIT_MAX_REQUESTS=120
# UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60

# --- Dataset-aware upload (Fase 0–2) ---
# 1/true/yes/on = wajib pilih dataset di form upload (dan input manual); tanpa ini legacy boleh kosong.
# REQUIRE_DATASET_FOR_UPLOAD=0

# --- Alembic (migrasi skema) ---
# Jika kosong: pakai `database_url()` (biasanya sama dengan DATABASE_URL)
# ALEMBIC_DATABASE_URL=

# --- Skrip ETL `scripts/migrate_sqlite_to_mysql.py` ---
# SQLITE_SOURCE_PATH=D:/path/to/source.db
# MIGRATE_TARGET_URL=mysql+pymysql://...
# MYSQL_TARGET_URL=
# MYSQL_SOURCE_URL=mysql+pymysql://...
# SQLITE_BACKUP_PATH=D:/path/to/backup/data_backup.db

# --- File env tambahan (path absolut) dimuat setelah `.env`, tetap override=False ---
# DOTENV_PATH=/etc/webdash.env
